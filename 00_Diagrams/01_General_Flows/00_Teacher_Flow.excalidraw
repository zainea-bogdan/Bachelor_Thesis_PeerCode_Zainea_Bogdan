      "isDeleted": false,
      "boundElements": null,
      "updated": 1772051188433,
      "link": null,
      "locked": false,
      "text": "Pe ultima coloana, profesorul vede la fiecare \nstudent, status-ul acestuia in functie de metricele\nluate de pe githut, putand fi clasificat:\n- Notat integral (verde)\n- Notat partial (galben) - si se trece si punctaju partial\n- Necesita Verificare Manuala (rosu) - verifica profesorul\nmanual repo-ul acestuia.\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Pe ultima coloana, profesorul vede la fiecare \nstudent, status-ul acestuia in functie de metricele\nluate de pe githut, putand fi clasificat:\n- Notat integral (verde)\n- Notat partial (galben) - si se trece si punctaju partial\n- Necesita Verificare Manuala (rosu) - verifica profesorul\nmanual repo-ul acestuia.\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
