    {
      "id": "nSo9huDf7QxUbMyuXCoZf",
      "type": "text",
      "x": 194.32930951838216,
      "y": -2886.3447035229788,
      "width": 739.599365234375,
      "height": 875,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "cross-hatch",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bLQ",
      "roundness": null,
      "seed": 1792355725,
      "version": 163,
      "versionNonce": 1892395597,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1769592162508,
      "link": null,
      "locked": false,
      "text": "- pentru a eficientiza din ce am citit si intrebat chat ul :\n\nas putea sa initializez model_dict si pdf_convertor cand deschis fastapi ul \n\nfrom fastapi import FastAPI\nfrom marker.models import create_model_dict\nfrom marker.converters.pdf import PdfConverter\nfrom marker.renderers.chunks import ChunksRenderer\n\napp = FastAPI()\n\n# 🔒 resurse globale (per proces)\nmodel_dict = None\npdf_converter = None\n\n\n@app.on_event(\"startup\")\ndef startup_event():\n    global model_dict, pdf_converter\n\n    print(\"🔄 Loading Marker models...\")\n    model_dict = create_model_dict()\n\n    pdf_converter = PdfConverter(\n        artifact_dict=model_dict,\n        renderer=ChunksRenderer()\n    )\n\n    print(\"✅ Marker models loaded\")\n\n\n@app.on_event(\"shutdown\")\ndef shutdown_event():\n    print(\"🧹 Shutting down Marker service\")\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "- pentru a eficientiza din ce am citit si intrebat chat ul :\n\nas putea sa initializez model_dict si pdf_convertor cand deschis fastapi ul \n\nfrom fastapi import FastAPI\nfrom marker.models import create_model_dict\nfrom marker.converters.pdf import PdfConverter\nfrom marker.renderers.chunks import ChunksRenderer\n\napp = FastAPI()\n\n# 🔒 resurse globale (per proces)\nmodel_dict = None\npdf_converter = None\n\n\n@app.on_event(\"startup\")\ndef startup_event():\n    global model_dict, pdf_converter\n\n    print(\"🔄 Loading Marker models...\")\n    model_dict = create_model_dict()\n\n    pdf_converter = PdfConverter(\n        artifact_dict=model_dict,\n        renderer=ChunksRenderer()\n    )\n\n    print(\"✅ Marker models loaded\")\n\n\n@app.on_event(\"shutdown\")\ndef shutdown_event():\n    print(\"🧹 Shutting down Marker service\")\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
