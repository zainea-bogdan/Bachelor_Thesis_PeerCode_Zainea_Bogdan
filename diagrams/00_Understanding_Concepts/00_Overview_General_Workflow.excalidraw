      "updated": 1769590642568,
      "link": null,
      "locked": false,
      "text": "aici basically acel urlfile pe care il\niau din request\n\ne ca un buffer pe care tre sa il fac\nfisier temporar si sa il prelucrez\ndupa aceea sa returnez si sa il\nsterg din memorie.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "aici basically acel urlfile pe care il iau din request\n\ne ca un buffer pe care tre sa il fac\nfisier temporar si sa il prelucrez\ndupa aceea sa returnez si sa il\nsterg din memorie.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "C2u0rEzNQAKpYnJMGyZQo",
      "type": "text",
      "x": -1367.8600743482962,
      "y": -3655.408485552484,
      "width": 539.7596435546875,
      "height": 1075,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "cross-hatch",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bKr",
      "roundness": null,
      "seed": 1897383405,
      "version": 12,
      "versionNonce": 791738541,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "bi9Mv3nZChoreUVlL3gKi",
          "type": "arrow"
        }
      ],
      "updated": 1769590669624,
      "link": null,
      "locked": false,
      "text": "from fastapi import FastAPI, UploadFile, File, Form\nfrom pathlib import Path\nimport tempfile\n\nfrom marker.convert import convert_pdf  # marker\n\napp = FastAPI()\n\n@app.post(\"/ingest-pdf\")\nasync def ingest_pdf(\n    file: UploadFile = File(...),\n    courseId: str = Form(...)\n):\n try:\n    # 1. Creezi un fișier temporar\n    with tempfile.NamedTemporaryFile(\n        delete=False,\n        suffix=\".pdf\"\n    ) as tmp:\n        pdf_path = Path(tmp.name)\n\n        # 2. Scrii stream-ul UploadFile în fișier\n        while chunk := await file.read(1024 * 1024):\n            tmp.write(chunk)\n\n    # 3. AICI începe Marker (HTTP a dispărut complet)\n    document = convert_pdf(str(pdf_path))\n\n    # 4. Exemplu: extragi textul\n    pages_text = [\n        page.text for page in document.pages\n    ]\n\n    return {\n        \"courseId\": courseId,\n        \"pages\": len(document.pages),\n        \"preview\": pages_text[:1]\n    }\n\n    finally:\n        if tmp_path and os.path.exists(tmp_path):\n            os.remove(tmp_path)\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "from fastapi import FastAPI, UploadFile, File, Form\nfrom pathlib import Path\nimport tempfile\n\nfrom marker.convert import convert_pdf  # marker\n\napp = FastAPI()\n\n@app.post(\"/ingest-pdf\")\nasync def ingest_pdf(\n    file: UploadFile = File(...),\n    courseId: str = Form(...)\n):\n try:\n    # 1. Creezi un fișier temporar\n    with tempfile.NamedTemporaryFile(\n        delete=False,\n        suffix=\".pdf\"\n    ) as tmp:\n        pdf_path = Path(tmp.name)\n\n        # 2. Scrii stream-ul UploadFile în fișier\n        while chunk := await file.read(1024 * 1024):\n            tmp.write(chunk)\n\n    # 3. AICI începe Marker (HTTP a dispărut complet)\n    document = convert_pdf(str(pdf_path))\n\n    # 4. Exemplu: extragi textul\n    pages_text = [\n        page.text for page in document.pages\n    ]\n\n    return {\n        \"courseId\": courseId,\n        \"pages\": len(document.pages),\n        \"preview\": pages_text[:1]\n    }\n\n    finally:\n        if tmp_path and os.path.exists(tmp_path):\n            os.remove(tmp_path)\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
