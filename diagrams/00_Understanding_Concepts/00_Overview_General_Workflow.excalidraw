    {
      "id": "HjyyqGv_ifRGCEAAnRLS4",
      "type": "text",
      "x": 8267.835371374851,
      "y": -3422.423096896635,
      "width": 516.2396240234375,
      "height": 625,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "cross-hatch",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [
        "OLIOLw4oQnUcUoGwppmmy"
      ],
      "frameId": null,
      "index": "bO8",
      "roundness": null,
      "seed": 1543955011,
      "version": 5,
      "versionNonce": 1830916035,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1769596109241,
      "link": null,
      "locked": false,
      "text": "@app.post(\"/ingest-pdf\")\nasync def ingest_pdf(\n    file: UploadFile = File(...),\n    courseId: str = Form(...)\n):\n    # ... tot pipeline-ul tău\n\n    rag_chunks = build_rag_chunks(...)\n    embeddings = embed_rag_chunks(rag_chunks)\n    store_chunks_in_chroma(rag_chunks, embeddings)\n\n    forced_count = sum(\n        1 for c in rag_chunks\n        if c[\"metadata\"].get(\"forced\")\n    )\n\n    return {\n        \"status\": \"success\",\n        \"courseId\": courseId,\n        \"document\": {\n            \"filename\": file.filename,\n            \"chunksStored\": len(rag_chunks),\n            \"forcedChunks\": forced_count\n        }\n    }",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "@app.post(\"/ingest-pdf\")\nasync def ingest_pdf(\n    file: UploadFile = File(...),\n    courseId: str = Form(...)\n):\n    # ... tot pipeline-ul tău\n\n    rag_chunks = build_rag_chunks(...)\n    embeddings = embed_rag_chunks(rag_chunks)\n    store_chunks_in_chroma(rag_chunks, embeddings)\n\n    forced_count = sum(\n        1 for c in rag_chunks\n        if c[\"metadata\"].get(\"forced\")\n    )\n\n    return {\n        \"status\": \"success\",\n        \"courseId\": courseId,\n        \"document\": {\n            \"filename\": file.filename,\n            \"chunksStored\": len(rag_chunks),\n            \"forcedChunks\": forced_count\n        }\n    }",
      "autoResize": true,
      "lineHeight": 1.25
    },
