    {
      "id": "lDNCI8whLN52pzwTuEIzf",
      "type": "text",
      "x": 1319.0021971132421,
      "y": -3726.6457094677335,
      "width": 476.479736328125,
      "height": 1675,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "cross-hatch",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bLA",
      "roundness": null,
      "seed": 1519994349,
      "version": 41,
      "versionNonce": 664172141,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1769591800905,
      "link": null,
      "locked": false,
      "text": "def build_rag_chunks(\n    marker_chunks: list,\n    course_id: str,\n    max_tokens: int = 500\n):\n    rag_chunks = []\n    buffer = []\n    buffer_tokens = 0\n\n    for block in marker_chunks:\n        block_type = block[\"block_type\"]\n\n        # 1️⃣ Ignorăm imaginile (diagramele simple)\n        if block_type == \"Image\":\n            continue\n\n        # 2️⃣ Text, liste, headings\n        if block_type in {\"Text\", \"List\", \"Heading\"}:\n            text = html_to_text(block[\"html\"])\n\n        # 3️⃣ Tabele → text liniarizat\n        elif block_type == \"Table\":\n            text = html_to_text(block[\"html\"])\n        else:\n            continue\n\n        tokens = estimate_tokens(text)\n\n        # chunk prea mare → singur\n        if tokens > max_tokens:\n            rag_chunks.append({\n                \"text\": text,\n                \"metadata\": {\n                    \"course_id\": course_id,\n                    \"page\": block[\"page_num\"],\n                    \"type\": block_type,\n                    \"forced\": True\n                }\n            })\n            continue\n\n        # depășire → finalizezi chunk\n        if buffer_tokens + tokens > max_tokens:\n            rag_chunks.append({\n                \"text\": \"\\n\\n\".join(buffer),\n                \"metadata\": {\n                    \"course_id\": course_id,\n                    \"page\": block[\"page_num\"]\n                }\n            })\n            buffer = []\n            buffer_tokens = 0\n\n        buffer.append(text)\n        buffer_tokens += tokens\n\n    # ultimul chunk\n    if buffer:\n        rag_chunks.append({\n            \"text\": \"\\n\\n\".join(buffer),\n            \"metadata\": {\n                \"course_id\": course_id\n            }\n        })\n\n    return rag_chunks\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "def build_rag_chunks(\n    marker_chunks: list,\n    course_id: str,\n    max_tokens: int = 500\n):\n    rag_chunks = []\n    buffer = []\n    buffer_tokens = 0\n\n    for block in marker_chunks:\n        block_type = block[\"block_type\"]\n\n        # 1️⃣ Ignorăm imaginile (diagramele simple)\n        if block_type == \"Image\":\n            continue\n\n        # 2️⃣ Text, liste, headings\n        if block_type in {\"Text\", \"List\", \"Heading\"}:\n            text = html_to_text(block[\"html\"])\n\n        # 3️⃣ Tabele → text liniarizat\n        elif block_type == \"Table\":\n            text = html_to_text(block[\"html\"])\n        else:\n            continue\n\n        tokens = estimate_tokens(text)\n\n        # chunk prea mare → singur\n        if tokens > max_tokens:\n            rag_chunks.append({\n                \"text\": text,\n                \"metadata\": {\n                    \"course_id\": course_id,\n                    \"page\": block[\"page_num\"],\n                    \"type\": block_type,\n                    \"forced\": True\n                }\n            })\n            continue\n\n        # depășire → finalizezi chunk\n        if buffer_tokens + tokens > max_tokens:\n            rag_chunks.append({\n                \"text\": \"\\n\\n\".join(buffer),\n                \"metadata\": {\n                    \"course_id\": course_id,\n                    \"page\": block[\"page_num\"]\n                }\n            })\n            buffer = []\n            buffer_tokens = 0\n\n        buffer.append(text)\n        buffer_tokens += tokens\n\n    # ultimul chunk\n    if buffer:\n        rag_chunks.append({\n            \"text\": \"\\n\\n\".join(buffer),\n            \"metadata\": {\n                \"course_id\": course_id\n            }\n        })\n\n    return rag_chunks\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
